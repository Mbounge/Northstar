{
  "name": "competitor-terminal",
  "version": "0.7.9",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "check": "npm run typecheck && npm run test && npm run lint && npm run test:e2e",
    "check:release": "npm run check && npm run build",
    "test:ledger-foundation": "node --import tsx --test tests/northstar-architecture-boundaries.test.ts tests/northstar-ledger-value.test.ts tests/northstar-ledger-reducer.test.ts tests/northstar-ephemeral-ledger.test.ts tests/northstar-ledger-context.test.ts tests/northstar-task-controller.test.ts",
    "test:e2e:legacy-baseline": "NORTHSTAR_RUN_LEGACY_BASELINE=1 PLAYWRIGHT_BROWSERS_PATH=0 playwright test e2e/northstar-existing-failures.spec.ts",
    "test:phase2": "node --import tsx --test tests/northstar-turn-architecture-boundaries.test.ts tests/northstar-turn-protocol.test.ts tests/northstar-turn-executor.test.ts tests/northstar-turn-gemini.test.ts tests/northstar-turn-data-tools.test.ts tests/northstar-turn-client.test.ts tests/northstar-turn-task-adapter.test.ts tests/northstar-phase2-ledger-draft.test.ts",
    "test:phase3": "node --import tsx --test tests/northstar-projection-architecture.test.ts tests/northstar-projection-validation.test.ts tests/northstar-projection-state.test.ts tests/northstar-projection-prepare.test.ts tests/northstar-projection-projector.test.ts tests/northstar-projection-window-surface.test.ts tests/northstar-phase3-controller.test.ts",
    "test:e2e:phase3": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --config=playwright.phase3.config.ts e2e/northstar-projection-runtime.spec.ts",
    "test:phase4": "node --import tsx --test tests/northstar-phase4-architecture.test.ts tests/northstar-workspace-runtime.test.ts",
    "test:e2e:phase4": "npm run build:e2e:phase4 && PLAYWRIGHT_BROWSERS_PATH=0 playwright test --config=playwright.phase4.config.ts e2e/northstar-phase4-architecture.spec.ts; status=$?; rm -rf .northstar-e2e test-results; exit $status",
    "build:e2e:phase4": "mkdir -p .northstar-e2e && esbuild e2e/northstar-phase4-browser-entry.tsx --bundle --platform=browser --format=iife --outfile=.northstar-e2e/phase4-browser-harness.js --alias:@=. --define:process.env.NODE_ENV=\\\"test\\\" --define:process.env.NEXT_PUBLIC_SUPABASE_URL=\\\"http://127.0.0.1:54321\\\" --define:process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY=\\\"northstar-e2e\\\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.99.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-compare-slider": "^3.1.0",
    "react-dom": "19.2.3",
    "react-zoom-pan-pinch": "^3.7.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
